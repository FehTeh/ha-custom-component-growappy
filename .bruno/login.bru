meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/v2/auth/token
  body: json
  auth: none
}

body:json {
  {
    "username": "{{username}}",
    "password": "{{password}}"
  }
}

script:post-response {
  bru.setEnvVar("accessToken", res.body.access);
  bru.setEnvVar("refreshToken", res.body.refresh);
}